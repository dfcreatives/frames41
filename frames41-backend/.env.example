# Database
DATABASE_URL="postgresql://neondb_owner:npg_9WQpqn3LdjJw@ep-empty-meadow-amb1cch8-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Application
NODE_ENV="development"
PORT=3000
API_VERSION="v1"
APP_NAME="Frames41 API"
APP_URL="http://localhost:3000"

# Security
JWT_ACCESS_SECRET="your-super-secret-access-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"
BCRYPT_ROUNDS="12"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# CORS
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"

# Logging
LOG_LEVEL="info"
LOG_DIR="./logs"
LOG_RETENTION_DAYS="14"

# Email (Resend) — signup verification & transactional mail
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@frames41.com"
RESEND_FROM_NAME="Frames41"
EMAIL_VERIFICATION_EXPIRY_MINUTES="10"
# Skip Resend entirely in dev (just log the code in the server console).
# Set to "true" for local testing when you haven't verified the sending
# domain on Resend yet. Only honored when NODE_ENV=development.
RESEND_DISABLE_IN_DEV="true"

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Shiprocket
SHIPROCKET_EMAIL=""
SHIPROCKET_PASSWORD=""

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""

# SMTP
